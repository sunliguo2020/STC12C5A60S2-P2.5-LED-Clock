void SetYue_G()	//
{
 	uchar row1,row2;

	row1=row*2;
	row2=row*2+1;

	shezhi();
	
	GD1[5]=HZ[14][row1];	//ЁАШеЁБ
	GD1[6]=HZ[14][row2];
	
	GD2[2]=HZ[19][row1];	//ККзждТ
	GD2[3]=HZ[19][row2] ;

	GD2[6]=HZ[20][row1];	  //ККзжШе
	GD2[7]=HZ[20][row2];



}


void SetYue_R()	//ЩшжУдТ
{
 	uchar row1,row2;
	row1=row*2;
	row2=row*2+1;
	
	RD1[5]=HZ[14][row1];	//ЁАдТЁБ
	RD1[6]=HZ[14][row2];

	
