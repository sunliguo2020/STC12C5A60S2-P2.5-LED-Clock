void shezhi()
{
 	uchar row1,row2;

	row1=row*2;
	row2=row*2+1;
	
	GD1[0]=HZ[22][row1];	//ЁАЩшжУЁБ
	GD1[1]=HZ[22][row2];
	GD1[2]=HZ[23][row1];	//
	GD1[3]=HZ[23][row2];
}
void SetNian_G()
{
 	uchar row1,row2;

	row1=row*2;
	row2=row*2+1;

	shezhi();
	GD1[4]=0;
	GD1[5]=HZ[16][row1];	//ЁАФъЁБ
	GD1[6]=HZ[16][row2];
	GD1[7]=0; 

//	GD2[4]=Num13[nian1][row];
//	GD2[5]=Num13[nian2][row];
//
//	if(SHAN&&Set_S==1)
//		GD2[4]=GD2[5]=0;
}

void SetNian_R()
{
 	uchar row1,row2;

	row1=row*2;
	row2=row*2+1;

	RD1[5]=HZ[16][row1];
	RD1[6]=HZ[16][row2];

	RD2[1]=Num13[ 2][row];
	RD2[2]=Num13[ 0][row];
	RD2[3]=Num13[nian1][row];
	RD2[4]=Num13[nian2][row];
	RD2[6]=HZ[16][row1];
	RD2[7]=HZ[16][row2];

	if(SHAN2)
		RD2[4]=RD2[3]=0;
}

