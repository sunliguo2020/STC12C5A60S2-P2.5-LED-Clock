void NTCbuchang_G()
{
	uchar row1,row2;
	row1=row*2;
	row2=row*2+1;

	GD1[0]=ZMlogo[11][row];	//N
	GD1[1]=ZMlogo[12][row];	//T
	GD1[2]=ZMlogo[13][row];	//C
	GD1[4]=HZ[30][row1];		//ВЙ
	GD1[5]=HZ[30][row2];
	GD1[6]=HZ[31][row1];		//ГЅ
	GD1[7]=HZ[31][row2];
	
	GD2[3]=Num12[10][row];
}

void NTCbuchang_R()
{
	
	RD2[0]=Num13[t1][row]>>5; 
	RD2[1]=Num13[t1][row]<<3 | Num13[t2][row]>>6; 
	RD2[2]=Num13[t2][row]<<2 ; 
	// RD2[0]=Num13[ADC_T/100][row];
	// RD2[1]=Num13[ADC_T%100/10][row];
	// RD2[2]=Num13[ADC_T%10][row];
	
	if(SHAN2)
	{
		 if(NTC_buchang<10)
		{
			RD2[6]=Num13[11][row];	//-	
			RD2[7]=Num13[10-NTC_buchang][row];
		}
		else
			RD2[7]=Num13[NTC_buchang-10][row];
		
		
/* 		RD2[6]=Num13[NTC_buchang/10][row];
		RD2[7]=Num13[NTC_buchang%10][row]; */
	}
}


void Yaokong_G()
{
	uchar row1,row2;
	row1=row*2;
	row2=row*2+1;
	
	shezhi();
	GD1[4]=HZ[35][row1];	//вЃ
	GD1[5]=HZ[35][row2];	//
	GD1[6]=HZ[36][row1];	//Пи
	GD1[7]=HZ[36][row2];	//
	
}


void Yaokong_R()
{
	uchar row1,row2;
	row1=row*2;
	row2=row*2+1;

	RD1[4]=HZ[35][row1];	//вЃ
	RD1[5]=HZ[35][row2];	//
	RD1[6]=HZ[36][row1];	//Пи
	RD1[7]=HZ[36][row2];	//


	if(SHAN2)
	{
		if(IR_POW)
		{
			RD2[6]=HZ[48][row1];	//ПЊ
			RD2[7]=HZ[48][row2];	
		}
		else
		{
			RD2[6]=HZ[49][row1];	//Йи
			RD2[7]=HZ[49][row2];	
		}
	}
	
		if(row>7)
	{
		row1=row-8;
	
		RD2[0]=Num5[IR_date[0]>>4][row1];			//гУЛЇТы
		RD2[1]=Num5[IR_date[0]&0x0f][row1]<<2;	//
		RD2[2]=Num5[IR_date[2]>>4][row1];			//МќТы
		RD2[3]=Num5[IR_date[2]&0x0f][row1]<<2;	//
	}	

}


void Xuexi_G()
{
	uchar row1,row2,a1,a2,a3,a4;
	row1=row*2;
	row2=row*2+1;
	switch(Set_S)
	{
		case 12:  a1=2;  a2=14;  a3=12;	a4=1;	break;	//SET	
		case 13:  a1=15;  a2=16;  a3=19;	a4=2;	break;	//Мг
		case 14:  a1=17;  a2=18;  a3=19;	a4=3;	break;	//Мѕ
		case 15:  a1=14;  a2=2;  a3=13;	a4=4;	break;	//ESC
		
		default : break;
	}
	
	if(xuexi_OK)
	{				//бЇЯАГЩЙІ
		GD1[0]=ZMlogo[a1][row];
		GD1[1]=ZMlogo[a2][row];
		GD1[2]=ZMlogo[a3][row];
		
		if(row>7)
		{
			row1=row-8;
		
			GD2[4]=Num5[IR_Key[0]>>4][row1];			//гУЛЇТы
			GD2[5]=Num5[IR_Key[0]&0x0f][row1]<<2;	//
			GD2[6]=Num5[IR_Key[a4]>>4][row1];			//МќТы
			GD2[7]=Num5[IR_Key[a4]&0x0f][row1]<<2;	//
		}
	}
	else
	{
		GD1[0]=HZ[37][row1];	//ЁАбЇЁБ
		GD1[1]=HZ[37][row2];
		GD1[2]=HZ[38][row1];	//"ЯА"
		GD1[3]=HZ[38][row2];		
		GD1[5]=ZMlogo[a1][row];
		GD1[6]=ZMlogo[a2][row];
		GD1[7]=ZMlogo[a3][row];
	}

}


void Xuexi_R()
{
	uchar row1,row2,a1,a2,a3,a4;
	row1=row*2;
	row2=row*2+1;
	switch(Set_S)
	{
		case 12:  a1=2;  a2=14;  a3=12;	a4=1;	break;	//SET	
		case 13:  a1=15;  a2=16;  a3=19;	a4=2;	break;	//Мг
		case 14:  a1=17;  a2=18;  a3=19;	a4=3;	break;	//Мѕ
		case 15:  a1=14;  a2=2;  a3=13;	a4=4;	break;	//ESC
		
		default : break;
	}
	
	if(xuexi_OK)
	{				//бЇЯАГЩЙІ
		RD1[0]=ZMlogo[a1][row];
		RD1[1]=ZMlogo[a2][row];
		RD1[2]=ZMlogo[a3][row];
		RD1[4]=HZ[37][row1];	//ЁАбЇЁБ
		RD1[5]=HZ[37][row2];
		RD1[6]=HZ[38][row1];	//"ЯА"
		RD1[7]=HZ[38][row2];	
		
		RD2[0]=HZ[39][row1];	//ЁАГЩЁБ
		RD2[1]=HZ[39][row2];
		RD2[2]=HZ[40][row1];	//"ЙІ"
		RD2[3]=HZ[40][row2];	

	}	
	else
	{
		RD1[5]=ZMlogo[a1][row];
		RD1[6]=ZMlogo[a2][row];
		RD1[7]=ZMlogo[a3][row];
		
		RD2[0]=HZ[33][row1];	//Чы
		RD2[1]=HZ[33][row2];	//
		RD2[2]=HZ[34][row1];	//АД
		RD2[3]=HZ[34][row2];	//
		RD2[4]=HZ[35][row1];	//вЃ
		RD2[5]=HZ[35][row2];	//
		RD2[6]=HZ[36][row1];	//Пи
		RD2[7]=HZ[36][row2];	//
	}	
}



