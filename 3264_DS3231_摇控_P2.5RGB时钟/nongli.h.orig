uchar code day_code1[9]={0x0,0x1f,0x3b,0x5a,0x78,0x97,0xb5,0xd4,0xf3};		//1-9月
uint  code day_code2[3]={0x111,0x130,0x14e};		 //10-12月

uchar get_moon_day(uchar month_p, uint table_addr)
{
	uchar rtn=29;
	switch (month_p)
	{
	case 1:
		if(year_code[table_addr]&0x08) rtn=30;
		break;
	case 2:
		if(year_code[table_addr]&0x04) rtn=30;
		break;
	case 3:
		if(year_code[table_addr]&0x02) rtn=30;
		break;
	case 4:
		if(year_code[table_addr]&0x01) rtn=30;
		break;
	case 5:
		if(year_code[table_addr+1]&0x80) rtn=30;
		break;
	case 6:
		if(year_code[table_addr+1]&0x40) rtn=30;
		break;
	case 7:
		if(year_code[table_addr+1]&0x20) rtn=30;
		break;
	case 8:
		if(year_code[table_addr+1]&0x10) rtn=30;
		break;
	case 9:
		if(year_code[table_addr+1]&0x08) rtn=30;
		break;
	case 10:
		if(year_code[table_addr+1]&0x04) rtn=30;
		break;
	case 11:
		if(year_code[table_addr+1]&0x02) rtn=30;
		break;
	case 12:
		if(year_code[table_addr+1]&0x01) rtn=30;
		break;
	case 13:
		if(year_code[table_addr+2]&0x80) rtn=30;
		break;
	default:
		break;
	}
	return rtn;
}

void GetWeek(uchar year, uchar month, uchar day)	//根据日期取得星期，0-日，1-一...6-六
													//年为两位年，不考虑2010年以前
{
	uchar i;
	week=4;		//2010-1-1为周五

	for(i=10;i<year;i++)		//判断年
	{
		if(i%4==0)		//因为是2010~2099，因此简单判断
			week+=2;	//判断是否是闰年，闰年2月是29天。公式：366%7=2
		else
			week++;

		week%=7;
	}
	
	for(i=1;i<month;i++)	  //判断月
	{
		if(i==4 || i==6 || i==9 || i==11)
			week+=2;		//30%7=2
		else if(i==2)
		{
			if(year%4==0)
				week++;		//29%7=1
		}
		else
			week+=3;		//31%7=3

		week%=7;
	}
	week+=day;	   //判断星期
	week%=7;
}

//根据公历日期计算农历
//输入：nian1,nian2,yue1,yue2,ri1, ri2
//输出：NL_yue,NL_ri,RunYue
void GetNL_ri()
{	
	uchar mnum=12;	   	//查询公历年份对应的春节所在的月和日
	uchar idata year,month,date,mm,dd;
	uchar idata ldays;	//农历年距离当年元旦的天数
	uchar idata RunYue;
	uint idata days;		//当前日期距离当年元旦的天数
	uint idata addr;		//地址偏移量
	year=nian1*10+nian2;
	month=yue1*10+yue2;
	date=ri1*10+ ri2;
	addr=(uint)(year*3);
	mm=(year_code[addr+2]&0x60)>>5;
	dd=year_code[addr+2]&0x1f;
   
	if(mm==1)			  //计算当年春年离当年元旦的天数，春节只会在公历1月或2月
		ldays=dd-1;
	else
		ldays=dd+30;

	//计算公历日离当年元旦的天数，为了减少运算，用了两个表
	//day_code1[9],day_code2[3]
	//如果公历月在九月或前，天数会少于0xff，用表day_code1[9],
	//在九月后,天数大于0xff,用表day_code2[3]
	//如输入公历日为8月10日,则公历日离元旦天数为day_code1[8-1]+10-1
	//如输入公历日为11月10日,则公历日离元旦天数为day_code2[11-10]+10-1
	if (month<10)
		days=day_code1[month-1]+date-1;
	else
		days=day_code2[month-10]+date-1;
	if ((month>2)&&(year%4==0))			//如果公历月大于2月并且该年的2月为闰月，天数加1
		days+=1;

	if(days>=ldays)			//在春节后或就是春节
	{
		days-=ldays;			//距离春节的天数
	
		RunYue=(year_code[addr]&0xf0)>>4;	  	//判断闰月
		if(RunYue)
			mnum=13;
		for(NL_yue=1;NL_yue<=mnum;NL_yue++)	//逐次计算天数
		{
			NL_ri=get_moon_day(NL_yue, addr);
			if(days<NL_ri)
				break;
			else
				days-=NL_ri;
		}
		NL_ri=days+1;
	}	
	else	  //在春节前
	{
		addr-=3;
		days=ldays-days;		
		RunYue=(year_code[addr]&0xf0)>>4;	 //判断闰月
		if(RunYue)
			mnum=13;
		for(NL_yue=mnum;NL_yue>0;NL_yue--)
		{
			NL_ri=get_moon_day(NL_yue, addr);
			if(days<NL_ri)
				break;
			else
				days-=NL_ri;
		}
		NL_ri=NL_ri-days+1;
	}

	if(RunYue&&(NL_yue-RunYue)==1)
		RY=1;
	else
		RY=0;

	if(RunYue && NL_yue>RunYue)
		NL_yue-=1;
	if(NL_yue==1)		//一月显示正月
		NL_yue=0;

/******** 处理农历显示数据 ***************/
//	y1=NL_yue/10;
	y2=NL_yue;
	r1=NL_ri/10;
	r2=NL_ri%10;

	if(NL_yue<11)			  //1-10月
	{
		y1=14;			  //首位不显示
			
		if(RY)			//闰月显示闰
			y1=13;
	}	
	else
	{
		y2-=10;	
		y1=10;
	}


	 if(r2==0)			  //农历个位0显示为十
	 {
	 	r2=10;			  //10显示初十
		if(r1==1)
			r1=0;
	 }


	GetWeek(year, month, date);
	if(week==0)
		week=15;
}



