
/**************************字节读函数***************************************/
void Read_EEP()
{
	unsigned char i;
	IAP_DATA = 0x00;    //清空数据
	IAP_CONTR = 0x81;    //打开IAP,设置操作等待时间
	IAP_CMD = 0x01;    //字节读命令
	IAP_ADDRH = 0;	//设置高8位地址
	for(i=0;i<5;i++)
	{
		IAP_ADDRL = i;    //设置低8位地址
		IAP_TRIG = 0x5a;    //发送5ah到触发寄存器
		IAP_TRIG = 0xa5;    //发送a5h到触发寄存器
		_nop_();    //延时	
		IR_Key[i]=IAP_DATA;
	}
	IAP_CONTR = 0;    //关闭IAP 功能
}

/*****************************字节编程函数*****************************/
void Write_EEP()
{
	unsigned char i;
	IAP_CONTR = 0x81;    //打开IAP,设置操作等待时间
	IAP_CMD = 0x03;    //扇区擦除命令
	IAP_ADDRH = 0;	//设置高8位地址
	IAP_ADDRL = 0;    //设置低8位地址
	IAP_TRIG = 0x5a;    //发送5ah到触发寄存器
	IAP_TRIG = 0xa5;    //发送a5h到触发寄存器
	_nop_();    //延时

	IAP_CONTR = 0x81;    //打开IAP,设置操作等待时间
	IAP_CMD = 0x02;    //字节编程命令
	for (i=0;i<5;i++)
	{
		IAP_ADDRL = i;    //设置低8位地址
		IAP_DATA=IR_Key[i];
		IAP_TRIG = 0x5a;    //发送5ah到触发寄存器
		IAP_TRIG = 0xa5;    //发送a5h到触发寄存器
		_nop_();    //延时
	}

	IAP_CONTR = 0;    //关闭IAP 功能
}


